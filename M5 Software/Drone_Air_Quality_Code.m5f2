{"version":"V2.0","versionNumber":"V2.3.7","type":"basic","components":[{"name":"screen","type":"screen","layer":0,"screenId":"builtin","screenName":"","id":"__basic_screen","createTime":1762191163837,"x":0,"y":0,"width":320,"height":240,"backgroundColor":"#70bfda","size":0,"isSelected":true},{"name":"T","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"llVv^g$OSwJqMLOW","createTime":1762194646900,"x":220,"y":50,"color":"#ffffff","backgroundColor":"#70bfda","text":"T","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"H","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"y@mh4#*V&GLHtvGM","createTime":1762194646900,"x":219,"y":80,"color":"#ffffff","backgroundColor":"#70bfda","text":"H","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"P","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"nzxS`xR4HUjar8g4","createTime":1762194646900,"x":220,"y":110,"color":"#ffffff","backgroundColor":"#70bfda","text":"P","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"co2","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"zF9PwxE&WiHDefbx","createTime":1762194646900,"x":220,"y":140,"color":"#ffffff","backgroundColor":"#70bfda","text":"co2","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"voc","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"mAa``f@f-Xk`vn@@","createTime":1762194646900,"x":220,"y":170,"color":"#ffffff","backgroundColor":"#70bfda","text":"voc","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label0","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"nieFek6UojcaTp51","createTime":1762194646900,"x":80,"y":50,"color":"#ffffff","backgroundColor":"#70bfda","text":"Temperature:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label1","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"gioBtd=8Si^SQK@e","createTime":1762194646900,"x":115,"y":80,"color":"#ffffff","backgroundColor":"#70bfda","text":"Humidity:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label2","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"q-HE7JeANAqHo-Os","createTime":1762194646900,"x":118,"y":109,"color":"#ffffff","backgroundColor":"#70bfda","text":"Pressure:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label3","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"n2`JS`&TrM!x2FOc","createTime":1762194646900,"x":158,"y":140,"color":"#ffffff","backgroundColor":"#70bfda","text":"CO2:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label4","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"i0s9$TR1-jL8thNo","createTime":1762194646900,"x":157,"y":170,"color":"#ffffff","backgroundColor":"#70bfda","text":"VOC:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false}],"resources":[{"hardware":["hardware_button","hardware_pin_button","imu","rgb","i2c","speaker","sdcard"]},{"unit":["unit_envpro"]}],"units":[{"type":"unit_envpro","name":"envpro_0","portList":["A","PAHUB","Custom"],"portType":"A","userPort":[22,21],"id":"xv=6X_5tpphrXDBY","createTime":1765961082309,"bus":"i2c0","pahubPortList":[0,1,2,3,4,5],"pahubPort":0,"initBlockId":"*@R:$$jA|6`v4z**W)?f"}],"hats":[],"caps":[],"bases":[],"i2cs":[{"id":"i2c0","portType":"Custom","userPort":[22,21],"freq":"100000"}],"blockly":"<variables><variable id=\"WRsQlM{y=|WCF)ikfV%3\">temp</variable></variables><block type=\"unit_envpro_get_gas_resistance\" id=\"y,T1A~vw+Q^*|=O_W)-U\" disabled=\"true\" x=\"310\" y=\"-110\"><field name=\"NAME\">envpro_0</field></block><block type=\"basic_on_loop\" id=\"loop_block\" deletable=\"false\" x=\"710\" y=\"-110\"><mutation isUpdate=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_begin\" id=\"(67;tzZG9^dl)RsDfw2{\" disabled=\"true\"><next><block type=\"system_m5_update\" id=\"Ju(H=#Zsn{KIlAot!%tw\"><next><block type=\"variables_set\" id=\"lZO6T$05yb4(6+FZrZ6e\"><field name=\"VAR\" id=\"WRsQlM{y=|WCF)ikfV%3\">temp</field><value name=\"VALUE\"><block type=\"unit_envpro_get_pressure\" id=\"X^Z]B+Dsj:WP7.R^Tb+)\"><field name=\"NAME\">envpro_0</field></block></value></block></next></block></next></block></statement></block><block type=\"basic_on_setup\" id=\"setup_block\" deletable=\"false\" x=\"250\" y=\"-30\"><mutation isBegin=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_begin\" id=\"IMq2^]i+C+eyPpx:roh?\"><next><block type=\"i2c_init\" id=\"`F-y[B,Es9*Gh,Y!l6dH\"><field name=\"NAME\">0</field><field name=\"FREQ\">100000</field><value name=\"SCL\"><shadow type=\"math_number\" id=\"@WA7#qx7Qjl-_-[Cb$SL\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">22</field></shadow></value><value name=\"SDA\"><shadow type=\"math_number\" id=\"^:LuA4%919s0CXaagK#f\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">21</field></shadow></value><next><block type=\"unit_envpro_init\" id=\"*@R:$$jA|6`v4z**W)?f\"><field name=\"NAME\">envpro_0</field></block></next></block></next></block></statement></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":320,"height":240,"scale":0.77,"screenName":"","blockId":"","screenColorType":0,"rotation":1,"id":"builtin","createTime":1762191163833}],"logicWhenNum":0,"pythonCode":"# ENV PRO (BME688) + TF Card Logging — M5GO Core / UIFlow2.3.7\nimport M5\nfrom M5 import *\nfrom hardware import *\nfrom unit import ENVPROUnit\nfrom machine import SDCard, Pin, I2C\nimport time, os\n\nenv = None\nlabels, values = {}, {}\nlabel_saved = None\nlog_file = \"/sd/envpro_log.csv\"\nstart_time = 0\n\ndef setup():\n    global env, labels, values, label_saved, start_time\n\n    M5.begin()\n    Widgets.fillScreen(0x48AA90)\n\n    # --- Mount TF Card (built-in slot, SPI) ---\n    try:\n        sd = SDCard(slot=2, sck=Pin(18), miso=Pin(19), mosi=Pin(23), cs=Pin(4))\n        os.mount(sd, \"/sd\")\n        print(\"✅ TFCard mounted:\", os.listdir(\"/sd\"))\n    except Exception as e:\n        print(\"❌ TFCard mount failed:\", e)\n        Widgets.Label(\"TFCard mount failed!\", 40, 10, 1.0,\n                      0xFF0000, 0x48AA90, Widgets.FONTS.DejaVu12)\n        raise e\n\n    # --- UI Labels ---\n    names = [\"Temp (°C)\", \"Hum (%)\", \"Pres (hPa)\", \"Gas (kΩ)\"]\n    for i, n in enumerate(names):\n        y = 50 + i * 30\n        labels[n] = Widgets.Label(n + \":\", 40, y, 1.0,\n                                  0xFFFFFF, 0x48AA90, Widgets.FONTS.DejaVu18)\n        values[n] = Widgets.Label(\"--\", 200, y, 1.0,\n                                  0xFFFFFF, 0x48AA90, Widgets.FONTS.DejaVu18)\n    label_saved = Widgets.Label(\"Data Saved:\", 40, 200, 1.0,\n                                0xFFFFFF, 0x48AA90, Widgets.FONTS.DejaVu18)\n\n    # --- Initialize ENV PRO ---\n    i2c0 = I2C(0, scl=Pin(22), sda=Pin(21), freq=100000)\n    env = ENVPROUnit(i2c0)\n\n    # --- Prepare CSV header ---\n    with open(log_file, \"a\") as f:\n        if f.tell() == 0:\n            f.write(\"elapsed_s,temp_c,hum_pct,press_hpa,gas_kohm\\n\")\n\n    start_time = time.ticks_ms()\n\n\ndef loop():\n    global env\n    try:\n        T = env.get_temperature()\n        H = env.get_humidity()\n        P = env.get_pressure()\n        G = env.get_gas_resistance() / 1000.0  # Ω → kΩ\n\n        values[\"Temp (°C)\"].setText(f\"{T:.1f}\")\n        values[\"Hum (%)\"].setText(f\"{H:.1f}\")\n        values[\"Pres (hPa)\"].setText(f\"{P:.1f}\")\n        values[\"Gas (kΩ)\"].setText(f\"{G:.1f}\")\n\n        t_now = time.ticks_diff(time.ticks_ms(), start_time) / 1000.0\n        with open(log_file, \"a\") as f:\n            f.write(f\"{t_now:.2f},{T:.2f},{H:.2f},{P:.2f},{G:.2f}\\n\")\n\n        label_saved.setText(f\"Data Saved: {T:.1f},{H:.1f},{P:.1f},{G:.1f},{t_now:.1f}s\")\n\n    except Exception as e:\n        for v in values.values():\n            v.setText(\"--\")\n        label_saved.setText(\"Error reading sensor\")\n        print(\"Error:\", e)\n\n    M5.update()\n    time.sleep(0.5)\n\n\nif __name__ == \"__main__\":\n    setup()\n    while True:\n        loop()\n","customList":[]}